{
  "manifest_version": 3,
  "name": "YTDL Desktop Helper",
  "version": "1.1.0",
  "description": "Send any video page to your YTDL Desktop App, and inject a one-click download button on protected players like Kwik.cx.",
  "permissions": [
    "activeTab"
  ],
  "host_permissions": [
    "https://kwik.cx/*",
    "http://127.0.0.1:30123/*",
    "http://localhost:30123/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon.png",
      "48": "icon.png",
      "128": "icon.png"
    }
  },
  "content_scripts": [
    {
      "matches": [
        "https://kwik.cx/f/*",
        "https://kwik.cx/embed/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_end"
    }
  ],
  "icons": {
    "16": "icon.png",
    "48": "icon.png",
    "128": "icon.png"
  }
}
